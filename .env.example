# Butler runtime
BUTLER_ENVIRONMENT=development
BUTLER_LOG_LEVEL=info

# Service connection strings
BUTLER_POSTGRES_URL=postgres://butler:butler-dev-password@localhost:5432/butler?sslmode=disable
BUTLER_REDIS_URL=redis://localhost:6379/0

# Optional settings-at-rest encryption for Sprint 8 config overrides.
# When unset, Butler stores secret overrides in plaintext and logs a startup warning.
BUTLER_SETTINGS_ENCRYPTION_KEY=

# Model providers
BUTLER_MODEL_PROVIDER=openai
BUTLER_OPENAI_API_KEY=
BUTLER_OPENAI_MODEL=gpt-4o-mini
BUTLER_OPENAI_BASE_URL=https://api.openai.com/v1
BUTLER_OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime
BUTLER_OPENAI_TRANSPORT_MODE=ws-first
BUTLER_OPENAI_CODEX_MODEL=gpt-5.1-codex
BUTLER_OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api
BUTLER_GITHUB_COPILOT_MODEL=gpt-4o
BUTLER_OPENAI_TIMEOUT_SECONDS=60
BUTLER_MEMORY_PROFILE_LIMIT=20
BUTLER_MEMORY_EPISODIC_LIMIT=3
BUTLER_MEMORY_SCOPE_ORDER=session,user,global
BUTLER_EXTENSION_API_TOKENS=
BUTLER_SINGLE_TAB_TRANSPORT_MODE=dual
BUTLER_SINGLE_TAB_RELAY_HEARTBEAT_TTL_SECONDS=90

# Tool services
BUTLER_TOOL_BROKER_ADDR=127.0.0.1:10090
BUTLER_TOOL_BROWSER_NODE_BINARY=node
BUTLER_TOOL_BROWSER_SCRIPT_PATH=apps/tool-browser/scripts/browser_runtime.mjs
BUTLER_TOOL_BROWSER_LOCAL_ORCHESTRATOR_URL=http://127.0.0.1:8080
BUTLER_TOOL_BROWSER_LOCAL_BROWSER_BRIDGE_URL=http://127.0.0.1:29115
BUTLER_TOOL_BROWSER_LOCAL_ROLLOUT_MODE=native_only
BUTLER_TOOL_BROWSER_LOCAL_DISPATCH_MODE=browser_bridge
BUTLER_TOOL_BROWSER_LOCAL_REQUEST_TIMEOUT_SECONDS=15
BUTLER_BROWSER_BRIDGE_ORCHESTRATOR_URL=http://127.0.0.1:8080
BUTLER_BROWSER_BRIDGE_CONTROL_ADDR=127.0.0.1:29115
BUTLER_BROWSER_BRIDGE_REQUEST_TIMEOUT_SECONDS=15
BUTLER_WEBFETCH_SELF_HOSTED_BASE_URL=
BUTLER_WEBFETCH_JINA_BASE_URL=https://r.jina.ai/http://
BUTLER_WEBFETCH_JINA_AUTH_TOKEN=
BUTLER_WEBFETCH_PLAIN_HTTP_ENABLED=true
BUTLER_DOCTOR_CONTAINER_TARGETS=

# Telegram adapter
BUTLER_TELEGRAM_BOT_TOKEN=
BUTLER_TELEGRAM_ALLOWED_CHAT_IDS=
BUTLER_TELEGRAM_BASE_URL=https://api.telegram.org
BUTLER_TELEGRAM_POLL_TIMEOUT_SECONDS=25

# Tool registry placeholder
BUTLER_TOOL_REGISTRY_PATH=configs/tools.json
BUTLER_TOOL_DEFAULT_TARGET=local
