# Butler runtime
BUTLER_ENVIRONMENT=development
BUTLER_LOG_LEVEL=info

# Infrastructure images
BUTLER_POSTGRES_IMAGE=pgvector/pgvector:pg17
BUTLER_REDIS_IMAGE=redis:7.4-alpine

# PostgreSQL bootstrap
BUTLER_POSTGRES_DB=butler
BUTLER_POSTGRES_USER=butler
BUTLER_POSTGRES_PASSWORD=butler-dev-password
BUTLER_POSTGRES_PORT=5432

# Redis bootstrap
BUTLER_REDIS_PORT=6379

# Service connection strings
BUTLER_POSTGRES_URL=postgres://butler:butler-dev-password@localhost:5432/butler?sslmode=disable
BUTLER_REDIS_URL=redis://localhost:6379/0

# Model and channel credentials
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
