{
  "name": "butler-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint": "npm run lint:ts && npm run lint:css",
    "lint:ts": "eslint .",
    "lint:css": "stylelint \"app/**/*.{css,vue}\" \"widgets/**/*.vue\" \"features/**/*.vue\" \"entities/**/*.vue\" \"shared/**/*.vue\" \"layouts/**/*.vue\" \"pages/**/*.vue\" \"components/**/*.vue\" \"assets/css/**/*.css\"",
